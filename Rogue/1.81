MACRO 16777218 "出现" Ability_Ambush
/run local _, _, active = GetShapeshiftFormInfo(1) if active then CastShapeshiftForm(1)end
END
MACRO 16777234 "出血" Spell_Shadow_LifeDrain
/startattack
/cast [mybuff:切割<1]切割
/cast [mybuff:切割<4,combo:=5]切割
/cast [combo:>4,nodebuff:破甲]破甲
/cast 还击
/cast [combo:<5]出血
/use [mypower:<15,mybuff:剑刃乱舞]菊花茶
/use [mybuff:剑刃乱舞]13
/use [mybuff:剑刃乱舞]14
/use [myhp:<=50]特效治疗石
/use [myhp:<=45]特效治疗药水
/use [myhp:<=40]诺达纳尔草药茶
END
MACRO 16777219 "剔骨" Ability_Rogue_Eviscerate
/startattack
/cast 剔骨
/run ToggleSheath()
/follow Nyxsight
END
MACRO 16777231 "大招" Spell_Shadow_ShadowWordDominate
/cast [mypower:<41]冲动
/use [mypower:<35,nodebuff:破甲,combo:<4]菊花茶
/run  UseInventoryItem(13)
/run  UseInventoryItem(14)
/cast 感知(种族特长)
/run for b=0,4 do for s=1,GetContainerNumSlots(b,s)do local n=GetContainerItemLink(b,s)if n and UnitClassification("target") == "worldboss" and (strfind(n,"加速药水") or strfind(n,"魂能之速"))then UseContainerItem(b,s,1)end end end
END
MACRO 16777230 "打断" Ability_Kick
/run  if CheckInteractDistance("target",3) then CastSpellByName("脚踢") else CastSpellByName("致命投掷"); end; 
/run if not TeM then TeM = GetTime() + 10 end if GetTime() > TeM then SendChatMessage("%t Kicked","SAY") TeM = nil end
END
