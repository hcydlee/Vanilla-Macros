/kneel
/下跪
END
MACRO 1 "Mount" Ability_Mount_RidingHorse
/rm
/script  local z=GetZoneText() if z=="安其拉" then CastSpellByName("召唤黄色其拉作战坦克") else CastSpellByName("迅捷红色战羊") end
END
MACRO 4 "Reset" Ability_Creature_Cursed_01
/run ResetInstances()
END
MACRO 3 "Roll" Ability_Creature_Cursed_04
