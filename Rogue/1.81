MACRO 5 "清内存" Ability_Creature_Cursed_04
/script T,F=T or 0,F or CreateFrame("frame")if X then print("off") X=nil else print("on") X=function()local t=GetTime()if t-T>10 then collectgarbage() T=t end end end F:SetScript("OnUpdate",X)
END
MACRO 16 "焦点" Ability_Creature_Cursed_04
/focus
END
MACRO 19 "雪球" Ability_Creature_Cursed_05
/run dosnowball()
/run dopig()
/run n,s=UnitName,UnitIsUnit;y,p,r,t="player","raid","party","target";for i=1,40 do a=((n(r..i)and r..i)or(n(p..i) and p..i)or nil);z=a and(not s(a,y)) and s(a..t,t) and SendChatMessage("Blind you: "..n(t),"WHISPER",nil,n(a))end




MACRO 16777220 "CD" Ability_CheapShot
/run for i=1,200 do local n, r = GetSpellName(i, "spell"); if n=="闪避" then local s,d,e=GetSpellCooldown(i,"spell"); message(i); message(format("%s: Start=%.1f, Duration=%.1f", n,s,d)); end end
END
MACRO 16777225 "F切割" Ability_Rogue_SliceDice
/script local opts = {minhppercent=20, distance=3}; Cursive:Target("攻击", "HIGHEST_HP_RAID_MARK", opts)
/script local opts = {isnotbehind=1}; Cursive:Curse("切割", "target", opts)
/script local f,s=0,0 for i=0,31 do b=GetPlayerBuff(i) if b>=0 then t=GetPlayerBuffTexture(b) if strfind(t,"SliceDice")then f=1 s=GetPlayerBuffTimeLeft(b) end end end if (f==0 or s<3) and GetComboPoints("target")>0  then CastSpellByName("切割") end
/use [myhp:<=40]特效治疗石
/use [myhp:<=35]特效治疗药水
/use [myhp:<=30]诺达纳尔草药茶
END
MACRO 16777233 "伏击" Ability_Rogue_Ambush
/run if UnitExists("target") and not (UnitClassification("target") == "worldboss") then CastSpellByName("伏击"); end
/cast 背刺
END
MACRO 16777228 "偷窃" Ability_Ambush
/run if UnitExists("mouseover")then TargetUnit("mouseover") CastSpellByName("偷窃") TargetLastTarget() else CastSpellByName("偷窃") end
END
MACRO 16777226 "冲动" Spell_Shadow_ShadowWordDominate
