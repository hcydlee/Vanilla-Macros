MACRO 16777221 "PA毒蛇" Ability_Hunter_Quickshot
/run local _,_,_,_,isActive=GetPetActionInfo(10) if not isActive and not GetUnitName("pettarget") then PetAttack() end
/cast 毒蛇钉刺
/run for i=1,120 do local t=GetActionTexture(i) if t and string.find(t,"射击") then if not IsAutoRepeatAction(i) then UseAction(i) end end end
END
MACRO 16777217 "UberPet" Ability_EyeOfTheOwl
/run if UnitExists("target") then if UnitIsFriend("player","target") then AssistUnit("target");PetAttack();else if UnitExists("pettarget") and UnitIsUnit("target", "pettarget") then PetFollow();else PetAttack();end;end;else PetFollow();end;
END
MACRO 16777223 "印记" Ability_Hunter_SniperShot
/run local i,x=1,0 while UnitDebuff("target",i) do if UnitDebuff("target",i)=="Interface\\Icons\\Ability_Hunter_SniperShot" then x=1 end i=i+1 end if x==0 then CastSpellByName("猎人印记") else PetAttack()end
/hmdps
/run Interact(0)
/run PetAttack()
END
MACRO 16777224 "奥射" Ability_ImpalingBolt
/run if not GetUnitName("target")then TargetNearestEnemy()end
/cast 奥术射击(等级 1)
/run if CheckInteractDistance("target", 3)and not PlayerFrame.inCombat then AttackTarget()elseif not IsAutoRepeatAction(17)then CastSpellByName("自动射击")end
/hmdps
/run Interact(0)
/run PetAttack()
END
MACRO 16777226 "宠物" Ability_Hunter_MendPet
/run if not UnitExists("pet") then CastSpellByName("召唤宠物") else if UnitIsDead("pet") then CastSpellByName("复活宠物") else CastSpellByName("治疗宠物") end end
END
MACRO 16777227 "恐兽" Ability_Druid_Cower
/run if UnitCanAttack("player", "mouseover") and UnitCreatureType("mouseover")=="Beast" then TargetUnit("mouseover") CastSpellByName("恐吓野兽") TargetLastTarget() end; PetAttack()
END
MACRO 16777219 "生存" Ability_MeleeDamage
/run if UnitHealth("target")==0 and UnitExists("target") then ClearTarget(); end
/run if GetUnitName("target")==nil then TargetNearestEnemy(); end
/hmdps
/run ToggleSheath()
END
MACRO 16777222 "追踪" Ability_CheapShot
/run c=CastSpellByName t=GetTrackingTexture() if t and strfind(t,"_追踪") then c("Track Dragonkin") elseif t and strfind(t,"Dragon") then c("Track Demons") elseif t and strfind(t,"Fel") then c("Track Elementals") else c("追踪野兽") end
END
MACRO 16777228 "追踪亡灵" Ability_Creature_Cursed_02
/run c=CastSpellByName t=GetTrackingTexture() if t and strfind(t,"追踪") then c("Track Hidden") elseif t and strfind(t,"Stealth") then c("追踪亡灵") elseif t and strfind(t,"Dark") then c("Track Giants") else c("追踪人型生物") end
END
MACRO 16777220 "鹰狼" Ability_Hunter_Pet_Wolf
/run if CheckInteractDistance("target",3) and UnitIsUnit('player', 'targettarget') then CastSpellByName("灵猴守护") else if CheckInteractDistance("target",3) then CastSpellByName("孤狼守护") else CastSpellByName("雄鹰守护")end end
END
